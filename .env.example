# Copy to .env for local Docker Compose runs. Never put real keys in this file.
AISSTREAM_API_KEY=
OPENAI_API_KEY=
ANALYSIS_API_TOKEN=
ALLOW_UNAUTHENTICATED_ANALYSIS=true
FLIGHT_MODE=live
FLIGHT_PROVIDER=opensky
FLIGHT_API_BASE_URL=
FLIGHT_API_KEY=
FLIGHT_BBOXES=[[[-90,-180],[90,180]]]
FLIGHT_POLL_INTERVAL_MS=90000
OPEN_SKY_CLIENT_ID=
OPEN_SKY_CLIENT_SECRET=
CONFLICT_CONTEXT_MODE=live
CONFLICT_CONTEXT_PROVIDER=acled
CONFLICT_CONTEXT_LOOKBACK_DAYS=14
CONFLICT_CONTEXT_MAX_RESULTS=50
ACLED_ACCESS_TOKEN=
ACLED_USERNAME=
ACLED_PASSWORD=
