# API runtime configuration. Copy to apps/api/.env for local runs.
# Keep real secrets out of this example file.

NODE_ENV=development
HOST=127.0.0.1
PORT=4000
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:5173

AIS_MODE=live
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_BBOXES=[[[-90,-180],[90,180]]]
AISSTREAM_FILTER_MESSAGE_TYPES=PositionReport,StandardClassBPositionReport,ExtendedClassBPositionReport,ShipStaticData,StaticDataReport
AISSTREAM_API_KEY=

FLIGHT_MODE=live
FLIGHT_PROVIDER=opensky
FLIGHT_API_BASE_URL=
FLIGHT_API_KEY=
FLIGHT_BBOXES=[[[-90,-180],[90,180]]]
FLIGHT_POLL_INTERVAL_MS=90000
FLIGHT_STALE_AFTER_SECONDS=60
FLIGHT_PROVIDER_TIMEOUT_MS=10000
OPEN_SKY_CLIENT_ID=
OPEN_SKY_CLIENT_SECRET=

MARINE_WEATHER_MODE=live
MARINE_WEATHER_TIMEOUT_MS=10000
MARINE_WEATHER_CACHE_SECONDS=900
MARINE_WEATHER_CACHE_MAX_ENTRIES=200

FIRMS_MODE=live
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_DAY_RANGE=1
FIRMS_TIMEOUT_MS=10000
FIRMS_CACHE_SECONDS=900
FIRMS_CACHE_MAX_ENTRIES=200
FIRMS_MAX_DETECTIONS=150

ANALYSIS_MODE=live
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
ANALYSIS_API_TOKEN=
ALLOW_UNAUTHENTICATED_ANALYSIS=true

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
LOG_LEVEL=info
